# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/fishing_mall?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# 관리자 이메일 (콤마로 구분, 이 이메일로 가입한 계정에만 /admin 접근 허용)
ADMIN_EMAILS="admin@example.com"

# 토스페이먼츠 (https://docs.tosspayments.com)
TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxx"
TOSS_SECRET_KEY="test_sk_xxxxxxxxxxxx"

# KG이니시스 (https://manual.inicis.com)
INICIS_MID="INIpayTest"
INICIS_SIGN_KEY="SU5JTElURV9UUklQTEVERVNfS0VZU1RS"

# 네이버페이 (https://developer.pay.naver.com)
NAVERPAY_CLIENT_ID=""
NAVERPAY_CLIENT_SECRET=""
NAVERPAY_CHAIN_ID=""

# 스마트택배 (SweetTracker) - 택배 추적
# 발급: https://info.sweettracker.co.kr/apikey
SWEETTRACKER_API_KEY=""

# 재고 부족 임계치 (이 수치 이하면 알림)
LOW_STOCK_THRESHOLD="10"

# 알림 - 이메일 (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="낚시몰 <noreply@example.com>"
ADMIN_NOTIFY_EMAIL="bkk.noname.admin@gmail.com"

# 알림 - Slack Webhook (선택)
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

# 알림 작업 인증 토큰 (Cron 등에서 호출시)
NOTIFY_CRON_TOKEN="change-me-random-token"

# 적립금 정책
# 결제금액의 몇 %를 적립할지 (예: 0.01 = 1%)
POINT_EARN_RATE="0.01"

# 알리고 SMS (https://smartsms.aligo.in)
# 미설정시 콘솔에 인증코드 출력 (개발 모드)
ALIGO_API_KEY=""
ALIGO_USER_ID=""
ALIGO_SENDER=""

# 카카오 알림톡 (Aligo AlimTalk: https://kakaoapi.aligo.in)
# 미설정시 콘솔에 메시지 출력 (개발 모드, SMS와 별개로 키 분리 가능)
ALIMTALK_API_KEY=""
ALIMTALK_USER_ID=""
ALIMTALK_SENDER_KEY=""        # 카카오 채널 발신 프로필 키
ALIMTALK_SENDER=""            # 사전등록된 발신번호 (미설정시 ALIGO_SENDER 사용)
# 사전 심사받은 템플릿 코드 (필수 등록 후 입력)
ALIMTALK_TPL_ORDER_PAID=""
ALIMTALK_TPL_SHIPPING_STARTED=""
ALIMTALK_TPL_DELIVERY_COMPLETED=""
ALIMTALK_TPL_ORDER_CANCELLED=""
ALIMTALK_TPL_ORDER_REFUNDED=""

# 네이버 로그인 (https://developers.naver.com/apps)
# 콜백 URL: {NEXTAUTH_URL}/api/auth/callback/naver
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 카카오 로그인 (https://developers.kakao.com)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
