# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/fishing_mall?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# 관리자 이메일 (콤마로 구분, 이 이메일로 가입한 계정에만 /admin 접근 허용)
ADMIN_EMAILS="admin@example.com"

# 토스페이먼츠 (https://docs.tosspayments.com)
TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxx"
TOSS_SECRET_KEY="test_sk_xxxxxxxxxxxx"

# KG이니시스 (https://manual.inicis.com)
INICIS_MID="INIpayTest"
INICIS_SIGN_KEY="SU5JTElURV9UUklQTEVERVNfS0VZU1RS"

# 네이버페이 (https://developer.pay.naver.com)
NAVERPAY_CLIENT_ID=""
NAVERPAY_CLIENT_SECRET=""
NAVERPAY_CHAIN_ID=""

# 스마트택배 (SweetTracker) - 택배 추적
# 발급: https://info.sweettracker.co.kr/apikey
SWEETTRACKER_API_KEY=""

# 재고 부족 임계치 (이 수치 이하면 알림)
LOW_STOCK_THRESHOLD="10"

# 알림 - 이메일 (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="낚시몰 <noreply@example.com>"
ADMIN_NOTIFY_EMAIL="bkk.noname.admin@gmail.com"

# 알림 - Slack Webhook (선택)
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

# 알림 작업 인증 토큰 (Cron 등에서 호출시)
NOTIFY_CRON_TOKEN="change-me-random-token"

# 적립금 정책
# 결제금액의 몇 %를 적립할지 (예: 0.01 = 1%)
POINT_EARN_RATE="0.01"

# Sentry 에러 트래킹 (https://sentry.io)
# 미설정시 Sentry 비활성 — 빌드 정상, 캡쳐만 스킵
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""              # 클라이언트(브라우저) DSN — 보통 같은 값
SENTRY_ENV=""                          # production | staging | development
SENTRY_RELEASE=""                      # ${git sha} 등 (CI에서 주입)
NEXT_PUBLIC_SENTRY_ENV=""
NEXT_PUBLIC_SENTRY_RELEASE=""
# 소스맵 업로드용 (선택, 운영 디버깅 향상)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# PII 포함 여부 (사용자 이메일을 Sentry 로 보낼지) — 기본 false
SENTRY_INCLUDE_PII="false"

# ────────────────────────────────────────
# 보안 / 운영 (v6 추가)
# ────────────────────────────────────────

# 개인정보 암호화 키 (AES-256-GCM, 32바이트 hex = 64자)
# 생성: openssl rand -hex 32
# ⚠️ 운영 배포 전 필수 설정. 미설정시 더미키로 동작 (개발용)
# ⚠️ 절대 Git에 커밋 금지. 운영시 Secrets Manager 사용 권장
ENCRYPTION_KEY=""

# Cron 작업 인증 토큰 (만료/휴면 처리 등)
# 생성: openssl rand -base64 32
CRON_SECRET=""

# 토스페이먼츠 Webhook 서명 검증 키 (콘솔에서 발급)
TOSS_WEBHOOK_SECRET=""

# 사업자 등록번호 (현금영수증 발행시 발신자 정보)
BUSINESS_REGISTRATION_NUMBER=""

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL="info"

# 스토리지 (lib/storage.ts)
# 미설정시 로컬 fs(/public/uploads). 운영시 s3 권장
STORAGE_PROVIDER="local"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""
S3_FORCE_PATH_STYLE=""

# 알리고 SMS (https://smartsms.aligo.in)
# 미설정시 콘솔에 인증코드 출력 (개발 모드)
ALIGO_API_KEY=""
ALIGO_USER_ID=""
ALIGO_SENDER=""

# 카카오 알림톡 (Aligo AlimTalk: https://kakaoapi.aligo.in)
# 미설정시 콘솔에 메시지 출력 (개발 모드, SMS와 별개로 키 분리 가능)
ALIMTALK_API_KEY=""
ALIMTALK_USER_ID=""
ALIMTALK_SENDER_KEY=""        # 카카오 채널 발신 프로필 키
ALIMTALK_SENDER=""            # 사전등록된 발신번호 (미설정시 ALIGO_SENDER 사용)
# 사전 심사받은 템플릿 코드 (필수 등록 후 입력)
ALIMTALK_TPL_ORDER_PAID=""
ALIMTALK_TPL_SHIPPING_STARTED=""
ALIMTALK_TPL_DELIVERY_COMPLETED=""
ALIMTALK_TPL_ORDER_CANCELLED=""
ALIMTALK_TPL_ORDER_REFUNDED=""
ALIMTALK_TPL_ADMIN_NEW_ORDER=""

# 관리자 신규주문 알림
# 결제 완료시 다음 채널로 자동 알림 (알림톡 → 카톡 미수신시 SMS 자동 폴백)
ADMIN_NOTIFY_PHONE=""              # 콤마로 여러 번호: "01012345678,01098765432"
ADMIN_NEW_ORDER_NOTIFY="true"      # false 로 끌 수 있음
ADMIN_NEW_ORDER_FORCE_SMS="false"  # true: 알림톡과 별개로 SMS 도 추가 발송

# 네이버 로그인 (https://developers.naver.com/apps)
# 콜백 URL: {NEXTAUTH_URL}/api/auth/callback/naver
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 카카오 로그인 (https://developers.kakao.com)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
