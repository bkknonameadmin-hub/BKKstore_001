generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  CS_AGENT     // 고객 응대만 가능
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  DORMANT       // 1년 미접속 휴면
  WITHDRAWN     // 탈퇴 (개인정보 분리/파기 대기)
  SUSPENDED     // 운영자가 정지
}

model User {
  id                String     @id @default(cuid())
  /// 로그인 아이디 (4~20자, 영소문자/숫자/언더스코어, 소문자 정규화 저장)
  /// - Credentials 가입자는 필수
  /// - OAuth 전용 가입자는 null 가능 (소셜로그인은 아이디 불필요)
  username          String?    @unique
  email             String     @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  name              String
  /// 평문 노출 호환 컬럼 (운영시 phoneEnc 만 사용 권장)
  phone             String?
  /// 암호화된 전화번호 (AES-256-GCM)
  phoneEnc          String?
  /// 검색용 SHA-256 해시 (앞자리/뒷자리)
  phoneHash         String?
  phoneVerifiedAt   DateTime?
  pointBalance      Int        @default(0)
  /// 누적 결제 금액 (결제완료~배송완료 합산) — 회원 등급 산정 기준
  lifetimeAmount    Int        @default(0)
  passwordChangedAt DateTime?
  role              UserRole   @default(CUSTOMER)
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  dormantAt         DateTime?
  withdrawnAt       DateTime?
  withdrawReason    String?
  /// 2단계 인증 (TOTP)
  totpSecretEnc     String?                       // AES-256-GCM 암호화된 secret
  totpEnabled       Boolean    @default(false)
  totpEnabledAt     DateTime?
  totpBackupCodes   String[]   @default([])       // bcrypt 해시 (1회 사용)
  /// 이메일 인증 발송 시각 (가입후 N일 미인증시 알림)
  emailVerifySentAt DateTime?
  /// 본인확인기관(NICE/KCB/PASS 등) 발급 CI — 동일인 식별 (88자)
  ci                 String?    @unique
  /// 본인확인기관 발급 DI — 사이트 내 중복가입 식별 (64자)
  di                 String?
  /// 본인인증 완료 시각
  identityVerifiedAt DateTime?
  /// 본인인증 provider (nice/kcb/kcp/mock 등)
  identityProvider   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  addresses    Address[]
  orders       Order[]
  reviews      Review[]
  wishlist     Wishlist[]
  userCoupons  UserCoupon[]
  pointHistory PointHistory[]
  loginLogs    LoginLog[]
  accounts     Account[]
  sessions     Session[]
  refundRequests   RefundRequest[]
  returnRequests   ReturnRequest[]
  auditLogs        AuditLog[]      @relation("ActorAudit")
  productQuestions ProductQuestion[]
  supportTickets   SupportTicket[]
  stockNotifications StockNotification[]
  passwordResetTokens PasswordResetToken[]

  @@index([status])
  @@index([phoneHash])
  @@index([role])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PhoneVerification {
  id         String    @id @default(cuid())
  /// 정규화된 평문 (단기 보관)
  phone      String
  /// 검색용 해시
  phoneHash  String?
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  ip         String?
  userId     String?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([phoneHash, createdAt])
  @@index([expiresAt])
}

/// 동의 기록 (전자상거래법·개인정보보호법 입증용)
/// 회원가입/주문/마케팅 동의 시점/내용을 변경 불가능 형태로 보관
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String?
  email       String?
  /// 동의 종류: "tos" | "privacy" | "marketing" | "third_party" | "age_14" 등
  type        String
  /// 동의 여부
  agreed      Boolean
  /// 동의 시 노출된 약관 버전/해시 (감사용)
  version     String?
  /// 컨텍스트: "register" | "checkout" | "settings"
  source      String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, type, createdAt])
  @@index([email, type, createdAt])
}

/// 회원 데이터 export 요청 (개인정보보호법 접근권 대응)
model DataExportRequest {
  id           String    @id @default(cuid())
  userId       String
  status       String    @default("PENDING") // PENDING | PROCESSING | READY | FAILED | EXPIRED
  /// 임시 다운로드 URL (서명 URL 또는 인증 토큰 포함)
  downloadKey  String?   @unique
  expiresAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([status])
}

/// 비밀번호 재설정 토큰 (이메일 링크 기반)
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 해시 저장 (평문 토큰은 발송 직후 폐기)
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

/// 본인확인기관(NICE/KCB/PASS 등) 인증 세션
/// - PASS 앱/SMS/공동인증서 등으로 본인인증 후 결과를 1회용 토큰처럼 사용
/// - 아이디 찾기, 비밀번호 찾기, 회원가입 본인확인 공통
model IdentityVerification {
  id          String    @id @default(cuid())
  /// 본인확인기관에 전달한 요청 시퀀스 (콜백 매칭용)
  reqSeq      String    @unique
  provider    String    // 'nice' | 'kcb' | 'kcp' | 'mock'
  purpose     String    // 'find-id' | 'find-password' | 'register' | 'reverify'

  /// 인증 완료 후 채워지는 필드들 (provider 응답에서 추출)
  ci          String?   // 88자 (provider 간 동일인 식별)
  di          String?   // 64자 (사이트별 고유)
  name        String?   // 실명
  birthDate   String?   // YYYYMMDD
  phone       String?   // 010XXXXXXXX
  gender      String?   // 'M' | 'F'
  nationality String?   // 'L' (내국인) | 'F' (외국인)
  ageGroup    String?   // 0~9 (10대 단위)

  status      String    @default("PENDING") // PENDING | COMPLETED | FAILED | EXPIRED
  failReason  String?
  consumedAt  DateTime? // 1회 사용 후 마킹

  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime  // 일반적으로 5~10분

  @@index([ci])
  @@index([status, expiresAt])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  recipient String
  /// 평문 (호환)
  phone     String
  /// 암호화
  phoneEnc  String?
  zipCode   String
  address1  String
  address2  String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  /// 카테고리 랜딩 페이지에 표시할 짧은 설명
  description String?    @db.Text
  /// 배너 이미지 URL (랜딩 hero 배경)
  bannerImage String?
  /// 카테고리 쇼트컷에 사용할 이모지 (없으면 slug 매핑)
  iconEmoji   String?
  products    Product[]

  @@index([parentId, sortOrder])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  brand       String?
  description String?
  price       Int
  salePrice   Int?
  stock       Int      @default(0)
  lowStockThreshold Int?
  thumbnail   String?
  images      String[] @default([])
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  orderItems OrderItem[]
  reviews    Review[]
  wishlist   Wishlist[]
  questions  ProductQuestion[]
  stockNotifications StockNotification[]

  @@index([categoryId, isActive])
  @@index([isActive, isFeatured])
  @@index([isActive, createdAt])
  @@index([brand])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  optionType    String   @default("color")
  name          String
  colorHex      String?
  stock         Int      @default(0)
  priceModifier Int      @default(0)
  sku           String?  @unique
  thumbnail     String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@index([productId, isActive, sortOrder])
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  TOSS
  INICIS
  NAVERPAY
}

model Order {
  id              String          @id @default(cuid())
  orderNo         String          @unique
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  status          OrderStatus     @default(PENDING)
  totalAmount     Int
  itemsAmount     Int             @default(0)
  shippingFee     Int             @default(0)
  couponDiscount  Int             @default(0)
  pointUsed       Int             @default(0)
  pointEarned     Int             @default(0)
  refundedAmount  Int             @default(0)        // 누적 환불액

  recipient       String
  phone           String
  phoneEnc        String?
  zipCode         String
  address1        String
  address2        String?
  memo            String?

  provider        PaymentProvider?
  providerTxnId   String?
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  expiresAt       DateTime?       // PENDING 만료 시각 (예: 30분 후)
  courier         String?
  trackingNo      String?
  adminMemo       String?

  /// 현금영수증 발행 정보
  cashReceiptType   String?       // PERSONAL | BUSINESS | null
  cashReceiptNumber String?       // 휴대폰/사업자등록번호
  cashReceiptIssued Boolean @default(false)

  couponId        String?
  coupon          Coupon?         @relation(fields: [couponId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items          OrderItem[]
  pointHistory   PointHistory[]
  userCoupons    UserCoupon[]
  refundRequests RefundRequest[]
  returnRequests ReturnRequest[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([paidAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  name        String
  variantName String?
  price       Int
  quantity    Int
  refundedQuantity Int @default(0)

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  returnRequestItems ReturnRequestItem[]

  @@index([orderId])
  @@index([productId])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  orderItemId String?  @unique
  rating      Int
  content     String
  images      String[] @default([])
  isVerifiedPurchase Boolean @default(false)
  helpfulCount Int     @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isHidden, createdAt])
  @@index([userId, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  name            String
  discountType    DiscountType
  discountValue   Int
  minOrderAmount  Int          @default(0)
  maxDiscount     Int?
  validFrom       DateTime
  validUntil      DateTime
  totalQuantity   Int?
  issuedCount     Int          @default(0)
  usedCount       Int          @default(0)
  isActive        Boolean      @default(true)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userCoupons UserCoupon[]
  orders      Order[]

  @@index([isActive, validFrom, validUntil])
}

model UserCoupon {
  id        String   @id @default(cuid())
  userId    String
  couponId  String
  /// 결제대기 중 임시 hold (PENDING 주문에 점유 표시)
  reservedOrderId String?
  reservedAt DateTime?
  usedAt    DateTime?
  orderId   String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon  @relation(fields: [couponId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id])

  @@unique([userId, couponId])
  @@index([userId, usedAt, expiresAt])
  @@index([reservedOrderId])
}

model PointHistory {
  id          String    @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  orderId     String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@index([userId, createdAt])
}

/// 멱등성 키 (POST /api/orders 등 중복 제출 방지)
model IdempotencyKey {
  key        String   @id
  scope      String                  // "orders.create" 등
  userId     String?
  responseStatus Int
  responseBody   String   @db.Text
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
  @@index([userId, scope])
}

/// 관리자 활동 감사 로그
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?                  // 작업자 (User.id)
  actor      User?    @relation("ActorAudit", fields: [actorId], references: [id])
  actorEmail String?
  action     String                   // "order.refund", "product.delete" 등
  targetType String?                  // "Order", "Product"
  targetId   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

/// 환불 요청 (부분 환불 포함)
model RefundRequest {
  id           String       @id @default(cuid())
  orderId      String
  userId       String?
  amount       Int
  reason       String
  status       RefundStatus @default(REQUESTED)
  adminMemo    String?
  pgRefundId   String?      // PG 환불 거래번호
  processedAt  DateTime?
  createdAt    DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([status, createdAt])
}

enum ReturnStatus {
  REQUESTED          // 회원이 신청
  APPROVED           // 관리자 승인 (회수 라벨 발급)
  PICKED_UP          // 회수 완료
  COMPLETED          // 검수 후 환불/교환 완료
  REJECTED
  CANCELLED          // 회원이 취소
}

enum ReturnType {
  RETURN              // 반품
  EXCHANGE            // 교환
}

/// 반품/교환 요청
model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String
  userId       String?
  type         ReturnType   @default(RETURN)
  status       ReturnStatus @default(REQUESTED)
  reason       String
  reasonDetail String?
  /// 회수 송장 (관리자가 입력)
  pickupCourier   String?
  pickupTrackingNo String?
  refundAmount Int          @default(0)
  adminMemo    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])
  items ReturnRequestItem[]

  @@index([orderId])
  @@index([status, createdAt])
}

model ReturnRequestItem {
  id              String @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id])

  @@index([returnRequestId])
}

/// 상품 Q&A
model ProductQuestion {
  id         String   @id @default(cuid())
  userId     String?
  productId  String
  authorName String                                    // 마스킹 표시용
  isPrivate  Boolean  @default(false)                  // 비공개 (관리자 + 작성자만)
  question   String
  answer     String?
  answeredAt DateTime?
  answeredBy String?
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isHidden, createdAt])
  @@index([userId, createdAt])
}

enum SupportStatus {
  OPEN          // 회원 신규 문의
  PENDING       // 관리자 확인중
  ANSWERED      // 답변 완료 (회원 추가 답글 가능)
  CLOSED        // 종료
}

enum SupportCategory {
  ORDER         // 주문 관련
  PAYMENT       // 결제
  DELIVERY      // 배송
  PRODUCT       // 상품 문의
  REFUND        // 환불/반품
  ACCOUNT       // 계정
  ETC           // 기타
}

/// 1:1 문의 티켓
model SupportTicket {
  id           String          @id @default(cuid())
  ticketNo     String          @unique
  userId       String?
  guestEmail   String?
  guestPhone   String?
  guestName    String?
  category     SupportCategory @default(ETC)
  subject      String
  status       SupportStatus   @default(OPEN)
  orderId      String?
  assignedTo   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  closedAt     DateTime?
  lastMessageAt DateTime       @default(now())

  user     User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages SupportMessage[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([ticketNo])
}

/// 재입고 알림 신청 — 품절 상품에 대한 사용자 알림 요청
model StockNotification {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  /// 옵션 단위 알림이면 variantId, 단순 상품이면 null
  variantId  String?
  notifiedAt DateTime?              // 발송 완료 시각 (null = 대기 중)
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@index([productId, notifiedAt])
}

/// 공지사항
model Notice {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  /// IMPORTANT|EVENT|GENERAL — UI 강조용
  category   String   @default("GENERAL")
  isPinned   Boolean  @default(false)
  isPublished Boolean @default(true)
  viewCount  Int      @default(0)
  publishedAt DateTime @default(now())
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublished, isPinned, publishedAt])
}

/// FAQ (자주 묻는 질문)
model Faq {
  id         String   @id @default(cuid())
  /// SHOPPING|DELIVERY|RETURN|PAYMENT|ACCOUNT|ETC
  category   String   @default("ETC")
  question   String
  answer     String   @db.Text
  sortOrder  Int      @default(0)
  isPublished Boolean @default(true)
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublished, category, sortOrder])
}

/// 사이트 설정 (싱글톤 — id="default")
/// 관리자가 프론트 노출 콘텐츠를 코드 수정 없이 편집할 수 있게 해주는 키-값 저장소
model SiteSettings {
  id        String   @id @default("default")
  /// 히어로 캐러셀 슬라이드 배열 — { eyebrow, title, subtitle, cta, href, bgClass, image? }
  heroSlides       Json   @default("[]")
  /// 사이드 배너 (홈 우측 2칸) — [{ eyebrow, title, href, bgClass, emoji }]
  sideBanners      Json   @default("[]")
  /// 상단 고지 띠 (Header 위) — { enabled, text, href, bgColor, fgColor }
  noticeBar        Json   @default("{}")
  /// 푸터 사업자 정보 (env 오버라이드)
  footer           Json   @default("{}")
  /// 무료배송 기준 금액 (원)
  freeShippingMin  Int    @default(50000)
  /// 베스트/추천 섹션 노출 토글
  showBestSection     Boolean @default(true)
  showFeaturedSection Boolean @default(true)
  showNewSection      Boolean @default(true)
  /// 카테고리 쇼트컷 노출
  showCategoryShortcut Boolean @default(true)

  updatedAt DateTime @updatedAt
  updatedBy String?
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  authorType  String                            // CUSTOMER | ADMIN
  authorId    String?
  authorName  String
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}
