generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?                       // 소셜로그인 회원은 null
  name              String
  phone             String?
  phoneVerifiedAt   DateTime?                     // 휴대폰 인증 시각
  pointBalance      Int       @default(0)
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  reviews      Review[]
  wishlist     Wishlist[]
  userCoupons  UserCoupon[]
  pointHistory PointHistory[]
  loginLogs    LoginLog[]
  accounts     Account[]
  sessions     Session[]
}

/// NextAuth: OAuth 계정 연결 (네이버/카카오 등)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String                          // oauth, email 등
  provider           String                          // naver, kakao, credentials
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// NextAuth 세션 (DB 세션 미사용이지만 Adapter 호환을 위해 정의)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth: 이메일 인증 등 임시 토큰
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// 휴대폰 인증 코드 (6자리)
model PhoneVerification {
  id         String   @id @default(cuid())
  phone      String                                 // 정규화된 번호 (예: 01012345678)
  codeHash   String                                 // SHA-256 해시
  expiresAt  DateTime
  attempts   Int      @default(0)
  consumedAt DateTime?
  ip         String?
  userId     String?                                // 인증 요청 회원 (있으면)
  createdAt  DateTime @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  recipient String
  phone     String
  zipCode   String
  address1  String
  address2  String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  brand       String?
  description String?
  price       Int
  salePrice   Int?
  stock       Int      @default(0)            // 옵션이 없으면 이 값을 사용
  lowStockThreshold Int?
  thumbnail   String?
  images      String[] @default([])
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  orderItems OrderItem[]
  reviews    Review[]
  wishlist   Wishlist[]
}

/// 상품 옵션 (예: 색상)
model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  optionType    String   @default("color")  // color | size | etc
  name          String                      // 예: "레드", "블루"
  colorHex      String?                     // 표시용 컬러칩 (#FF0000)
  stock         Int      @default(0)
  priceModifier Int      @default(0)        // 기본가에 가산되는 추가금
  sku           String?  @unique
  thumbnail     String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  TOSS
  INICIS
  NAVERPAY
}

model Order {
  id              String          @id @default(cuid())
  orderNo         String          @unique
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  status          OrderStatus     @default(PENDING)
  totalAmount     Int                              // 최종 결제금액
  itemsAmount     Int             @default(0)      // 상품금액 합계
  shippingFee     Int             @default(0)
  couponDiscount  Int             @default(0)
  pointUsed       Int             @default(0)
  pointEarned     Int             @default(0)

  recipient       String
  phone           String
  zipCode         String
  address1        String
  address2        String?
  memo            String?

  provider        PaymentProvider?
  providerTxnId   String?
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  courier         String?
  trackingNo      String?
  adminMemo       String?

  couponId        String?
  coupon          Coupon?         @relation(fields: [couponId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           OrderItem[]
  pointHistory   PointHistory[]
  userCoupons    UserCoupon[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  name        String
  variantName String?
  price       Int
  quantity    Int

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

/// 리뷰 (구매 인증 가능)
model Review {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  orderItemId String?  @unique
  rating      Int                            // 1-5
  content     String
  images      String[] @default([])
  isVerifiedPurchase Boolean @default(false)
  helpfulCount Int     @default(0)
  isHidden    Boolean  @default(false)        // 관리자가 숨긴 리뷰
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// 위시리스트
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum DiscountType {
  PERCENT
  FIXED
}

/// 쿠폰 마스터
model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique          // 등록 코드 (예: WELCOME2026)
  name            String
  discountType    DiscountType
  discountValue   Int                            // PERCENT: 1~100, FIXED: 원
  minOrderAmount  Int          @default(0)
  maxDiscount     Int?                           // PERCENT 쿠폰 상한
  validFrom       DateTime
  validUntil      DateTime
  totalQuantity   Int?                           // null = 무제한
  issuedCount     Int          @default(0)
  usedCount       Int          @default(0)
  isActive        Boolean      @default(true)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userCoupons UserCoupon[]
  orders      Order[]
}

/// 회원이 보유한 쿠폰
model UserCoupon {
  id        String   @id @default(cuid())
  userId    String
  couponId  String
  usedAt    DateTime?
  orderId   String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon  @relation(fields: [couponId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id])

  @@unique([userId, couponId])
}

/// 적립금 이력
model PointHistory {
  id          String    @id @default(cuid())
  userId      String
  amount      Int                              // +적립 / -사용
  reason      String                            // "주문 적립", "회원가입 축하" 등
  orderId     String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])
}

/// 로그인 시도 기록 (보안)
model LoginLog {
  id        String   @id @default(cuid())
  userId    String?                           // 실패시 null 가능
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([ip, createdAt])
}
